{
  "name": "@gitterm/cli",
  "version": "0.0.1",
  "description": "Complete suit of gitterm tools in one CLI",
  "keywords": [
    "gitterm",
    "opencode",
    "sync"
  ],
  "homepage": "https://gitterm.dev",
  "license": "MIT",
  "author": "Opeyemi Oginni",
  "bin": {
    "gitterm": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev:local": "bun --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "prepublishOnly": "bun run build",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "ora": "^8.2.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@gitterm/config": "workspace:*",
    "@gitterm/sdk": "workspace:*",
    "@types/bun": "^1.2.6",
    "@types/yargs": "^17.0.35",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
