{
  "name": "gitterm",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "hono": "^4.8.2",
      "@trpc/server": "^11.8.1",
      "better-auth": "^1.4.9",
      "dotenv": "^17.2.2",
      "zod": "^4.1.11",
      "typescript": "^5.8.2",
      "@trpc/client": "^11.8.1",
      "drizzle-orm": "^0.45.1",
      "drizzle-kit": "^0.31.8"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "dev:proxy": "turbo -F proxy dev",
    "dev:tunnel-agent": "turbo -F tunnel-agent dev",
    "dev:tunnel-proxy": "turbo -F tunnel-proxy dev",
    "dev:worker": "turbo -F worker dev",
    "dev:listener": "turbo -F listener dev",
    "dev:listener:ngrok": "turbo -F listener ngrok",
    "dev:proxy:ngrok": "turbo -F proxy ngrok",
    "db:push": "turbo -F @gitterm/db db:push",
    "db:studio": "turbo -F @gitterm/db db:studio",
    "db:generate": "turbo -F @gitterm/db db:generate",
    "db:migrate": "turbo -F @gitterm/db db:migrate",
    "db:start": "turbo -F @gitterm/db db:start",
    "db:watch": "turbo -F @gitterm/db db:watch",
    "db:stop": "turbo -F @gitterm/db db:stop",
    "db:down": "turbo -F @gitterm/db db:down",
    "db:seed": "turbo -F @gitterm/db db:seed",
    "db:seed-admin": "turbo -F server db:seed-admin",
    "redis:start": "turbo -F @gitterm/redis redis:start",
    "redis:stop": "turbo -F @gitterm/redis redis:stop",
    "redis:down": "turbo -F @gitterm/redis redis:down",
    "format": "bunx oxfmt@latest",
    "docker:opencode:build": "docker build -f .docker/Opencode.Dockerfile --platform linux/amd64 -t opeoginni/gitterm-opencode:latest .docker && docker push opeoginni/gitterm-opencode:latest",
    "docker:opencode-server:build": "docker build -f .docker/Opencode.Server.Dockerfile --platform linux/amd64 -t opeoginni/gitterm-opencode-server:latest .docker && docker push opeoginni/gitterm-opencode-server:latest",
    "docker:opencode-server-ssh:build": "docker build -f .docker/Opencode.Server.SSH.Dockerfile --platform linux/amd64 -t opeoginni/gitterm-opencode-server-with-ssh:latest .docker && docker push opeoginni/gitterm-opencode-server-with-ssh:latest",
    "docker:opencode-aws-server:build": "docker build -f .docker/Opencode.Server.AWS.Dockerfile --platform linux/amd64 -t opeoginni/gitterm-opencode-aws-server:latest .docker && docker push opeoginni/gitterm-opencode-aws-server:latest",
    "e2b:template-build": "turbo -F @gitterm/api e2b:build",
    "daytona:snapshot-build": "turbo -F @gitterm/api daytona:snapshot-build",
    "opencode-upgrade": "bun run docker:opencode:build && bun run docker:opencode-server:build && bun run docker:opencode-server-ssh:build && bun run docker:opencode-aws-server:build && bun run e2b:template-build && bun run daytona:snapshot-build"
  },
  "dependencies": {
    "@trpc/client": "^11.8.1",
    "@trpc/server": "^11.8.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.2",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.1",
    "oxfmt": "^0.37.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/bun": "^1.2.6",
    "turbo": "^2.9.6"
  },
  "packageManager": "bun@1.3.2"
}
