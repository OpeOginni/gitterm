{
  "name": "gitterm",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "hono": "^4.12.25",
      "@trpc/server": "^11.8.1",
      "better-auth": "^1.4.9",
      "dotenv": "^17.2.2",
      "zod": "^4.1.11",
      "typescript": "^5.8.2",
      "@trpc/client": "^11.8.1",
      "drizzle-orm": "^0.45.1",
      "drizzle-kit": "^0.31.8"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format:check": "oxfmt --check",
    "prepare": "husky",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "dev:proxy": "turbo -F proxy dev",
    "dev:tunnel-agent": "turbo -F tunnel-agent dev",
    "dev:tunnel-proxy": "turbo -F tunnel-proxy dev",
    "dev:worker": "turbo -F worker dev",
    "dev:listener": "turbo -F listener dev",
    "dev:listener:ngrok": "turbo -F listener ngrok",
    "dev:proxy:ngrok": "turbo -F proxy ngrok",
    "db:push": "turbo -F @gitterm/db db:push",
    "db:studio:dev": "turbo -F @gitterm/db db:studio:dev",
    "db:studio:prod": "turbo -F @gitterm/db db:studio:prod",
    "db:generate": "turbo -F @gitterm/db db:generate",
    "db:migrate:dev": "turbo -F @gitterm/db db:migrate:dev",
    "db:migrate:prod": "turbo -F @gitterm/db db:migrate:prod",
    "infra:up": "docker-compose up -d",
    "infra:stop": "docker-compose stop",
    "infra:down": "docker-compose down",
    "db:seed": "turbo -F @gitterm/db db:seed",
    "db:seed-admin": "turbo -F server db:seed-admin",
    "format": "oxfmt",
    "docker:agent": "bash scripts/build-agent-image.sh",
    "build:sdk": "turbo -F @gitterm/sdk build",
    "build:cli": "turbo -F @gitterm/cli build",
    "version:sdk": "npm version --no-git-tag-version --prefix packages/sdk",
    "version:cli": "npm version --no-git-tag-version --prefix packages/cli",
    "publish:sdk": "bun run build:sdk && npm publish ./packages/sdk --access public",
    "publish:cli": "bun run build:cli && npm publish ./packages/cli --access public",
    "publish:npm": "bun run publish:sdk && bun run publish:cli",
    "e2b:template-build": "turbo -F @gitterm/api e2b:build",
    "opencode-upgrade": "gh workflow run build-agent-images.yml"
  },
  "dependencies": {
    "@trpc/client": "^11.8.1",
    "@trpc/server": "^11.8.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.2",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.1",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/bun": "^1.2.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "turbo": "^2.9.6"
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxfmt",
      "oxlint"
    ]
  },
  "packageManager": "bun@1.3.2"
}
